# Python environments and cache
venv/
.venv/
__pycache__/
*.py[cod]

# Dataset artifacts (keep folder structure via .gitkeep)
datasets/**/*.csv
datasets/**/images/**
!datasets/**/images/
!datasets/**/images/.gitkeep

# Report and benchmark outputs (keep folder structure via .gitkeep)
results/**
!results/.gitkeep
!results/reports/
!results/reports/.gitkeep

# Optional top-level image dump folder
/Images/